YOUTUBE_API_KEY=coloca_tua_chave_aqui
AI_PROVIDER=ollama
AI_ANALYSIS_BATCH_SIZE=5
CONTENT_PROFILE=curiosity_ai_trends
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
AI_ANALYSIS_LIMIT=20
VIRAL_ONLY=true
MIN_TOTAL_VIEWS=1000000
MIN_VIEWS_PER_DAY=100000
MIN_OPPORTUNITY_SCORE=80
VIRAL_STRICT_MODE=true
DAYS_BACK=7
REGION_CODE=BR
MAX_RESULTS_PER_KEYWORD=25
DATABASE_PATH=data/database.sqlite
OLLAMA_MODE=cloud_direct
OLLAMA_API_KEY=
OLLAMA_BASE_URL=https://ollama.com
OLLAMA_MODEL=gpt-oss:120b
# Ollama Cloud direto:
# OLLAMA_MODE=cloud_direct
# OLLAMA_BASE_URL=https://ollama.com
# OLLAMA_MODEL=gpt-oss:120b
# OLLAMA_API_KEY=sua_chave
#
# Ollama Cloud via daemon local:
# OLLAMA_MODE=cloud_daemon
# OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_MODEL=gpt-oss:120b-cloud
#
# Ollama local:
# OLLAMA_MODE=local
# OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_MODEL=qwen:latest
#
# CONTENT_PROFILE define o perfil editorial usado pela IA.
# Valores aceitos:
# general
# curiosity_ai_trends
# finance
# history_mystery
# psychology_behavior
#
# VIRAL_ONLY=true aceita apenas vídeos com total de views e views/dia altos.
# MIN_TOTAL_VIEWS=1000000 exige pelo menos 1 milhão de views totais.
# MIN_VIEWS_PER_DAY=100000 exige pelo menos 100 mil views por dia.
# Se quiser mais resultados, usar:
# MIN_TOTAL_VIEWS=500000
# MIN_VIEWS_PER_DAY=50000
OPENROUTER_API_KEY=
OPENROUTER_MODEL=
GROQ_API_KEY=
GROQ_MODEL=
OPENAI_API_KEY=
OPENAI_MODEL=
